# Copy to .env and fill in. Load before running, e.g.:
#   export $(grep -v '^#' .env | xargs) && python3 main.py

# Scraping providers (get tokens from apify.com / brightdata.com)
APIFY_TOKEN=apify_api_xxxxxxxx
BRIGHTDATA_TOKEN=xxxxxxxx

# Login for the web dashboard (required — pick your own)
KOLWATCH_USER=your_username
KOLWATCH_PASS=your_strong_password

# Optional
KOLWATCH_PORT=5070
